# Database Configuration
# Replace with your actual PostgreSQL connection string
# Examples:
# - Neon: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
# - Supabase: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
# - Local: postgresql://postgres:password@localhost:5432/hireshield
DATABASE_URL="postgresql://postgres:password@localhost:5432/hireshield"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YXNzdXJpbmctbW91c2UtNzIuY2xlcmsuYWNjb3VudHMuZGV2JA
CLERK_SECRET_KEY=••••••••••••••••••••••••••••••••••••••••••••••••••
