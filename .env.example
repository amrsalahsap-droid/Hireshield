# Database Configuration
# Replace with your actual PostgreSQL connection string
# Examples:
# - Neon: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
# - Supabase: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
# - Local: postgresql://postgres:password@localhost:5432/hireshield
DATABASE_URL="postgresql://postgres:password@localhost:5432/hireshield"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/app

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_MODEL_DEFAULT=gpt-4o-mini
OPENAI_TEMPERATURE_DEFAULT=0.2
OPENAI_TIMEOUT_MS=30000
OPENAI_MAX_RETRIES=2
